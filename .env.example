# Construct runner environment
# Copy the values you need into .env for local development.

CONSTRUCT_RUNNER_PORT=43110

# Developer-controlled agent/provider configuration.
CONSTRUCT_AGENT_PROVIDER=openai
CONSTRUCT_SEARCH_PROVIDER=tavily
CONSTRUCT_OPENAI_MODEL=gpt-5.4
CONSTRUCT_TAVILY_SEARCH_DEPTH=advanced

# Optional if you need a custom gateway or proxy-compatible endpoint.
CONSTRUCT_OPENAI_BASE_URL=https://api.openai.com/v1

# Sample keys only. Replace with real secrets in your local .env.
OPENAI_API_KEY=sk-example-openai-key
TAVILY_API_KEY=tvly-example-tavily-key
