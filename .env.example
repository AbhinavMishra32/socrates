# Construct runner environment
# Copy the values you need into .env for local development.

CONSTRUCT_RUNNER_PORT=43110

# Persistence backend. Set to prisma to store planning state, knowledge,
# projects, and generated blueprints through Prisma.
CONSTRUCT_STORAGE_BACKEND=prisma
CONSTRUCT_USER_ID=local-user
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Developer-controlled agent/provider configuration.
CONSTRUCT_AGENT_PROVIDER=openai
CONSTRUCT_SEARCH_PROVIDER=tavily
CONSTRUCT_OPENAI_MODEL=gpt-5.4
CONSTRUCT_TAVILY_SEARCH_DEPTH=advanced
# 0 = warnings/errors only, 1 = normal info logs, 2 = verbose ops,
# 3 = full model trace (prompt bodies and raw model payloads in server logs).
CONSTRUCT_DEBUG_LEVEL=1
# Explicitly enable the in-app blueprint observability route and runner APIs.
CONSTRUCT_DEBUG_MODE=1

# Optional LangSmith tracing. Enable tracing and set an API key to capture
# LangGraph/LangChain runs while project creation executes.
CONSTRUCT_LANGSMITH_ENABLED=false
CONSTRUCT_LANGSMITH_PROJECT=construct-project-creation

# Optional if you need a custom gateway or proxy-compatible endpoint.
CONSTRUCT_OPENAI_BASE_URL=https://api.openai.com/v1

# Sample keys only. Replace with real secrets in your local .env.
OPENAI_API_KEY=sk-example-openai-key
TAVILY_API_KEY=tvly-example-tavily-key
LANGSMITH_API_KEY=lsv2_example_langsmith_key
LANGSMITH_TRACING=false
